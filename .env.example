# ============================================================
# 方式 1: 直接使用 Claude（推荐，内置适配层自动转换格式）
# 当检测到 api.anthropic.com 时自动启动内置代理，无需外部工具
# ============================================================
LLM_BASE_URL=https://api.anthropic.com/v1
LLM_API_KEY=your-anthropic-api-key-here
LLM_MODEL=claude-sonnet-4-20250514

# ============================================================
# 方式 2: 使用 OpenAI
# ============================================================
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your-openai-api-key-here
# LLM_MODEL=gpt-4o

# ============================================================
# 方式 3: 使用通义千问（page-agent 默认支持）
# ============================================================
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=your-dashscope-api-key-here
# LLM_MODEL=qwen3.5-plus

# ============================================================
# 方式 4: 通过外部代理使用 Claude（如 LiteLLM）
# 安装: pip install litellm[proxy]
# 启动: litellm --model anthropic/claude-sonnet-4-20250514 --port 4000
# ============================================================
# LLM_BASE_URL=http://localhost:4000/v1
# LLM_API_KEY=your-anthropic-api-key-here
# LLM_MODEL=claude-sonnet-4-20250514
