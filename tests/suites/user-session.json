      "steps": [
        { "tool": "navigate", "args": { "url": "https://www.camscanner.com/user/downloads" } },
        { "tool": "get_page_state" },
        { "tool": "screenshot" }
      ]
    },
    {
      "id": "SES-005",
      "name": "Cookie 检查",
      "description": "检查页面的 Cookie 信息",
      "steps": [
        { "tool": "navigate", "args": { "url": "https://www.camscanner.com/zh" } },
        { "tool": "execute_task", "args": { "task": "执行 JavaScript: document.cookie.split(';').length，报告 cookie 数量" } }
      ]
    },
    {
      "id": "SES-006",
      "name": "LocalStorage 检查",
      "description": "检查 localStorage 存储信息",
      "steps": [
        { "tool": "navigate", "args": { "url": "https://www.baidu.com" } },
        { "tool": "execute_task", "args": { "task": "执行 JavaScript: Object.keys(localStorage).length，报告数量" } }
      ]
    },
    {
      "id": "SES-007",
      "name": "SessionStorage 检查",
      "description": "检查 sessionStorage 存储信息",
      "steps": [
        { "tool": "navigate", "args": { "url": "https://www.camscanner.com/zh" } },
        { "tool": "execute_task", "args": { "task": "执行 JavaScript: Object.keys(sessionStorage).length，报告 sessionStorage 键数量" } }
