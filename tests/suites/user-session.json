      "name": "检测登录态",
      "description": "检查页面上的登录状态标识",
      "steps": [
        { "tool": "navigate", "args": { "url": "https://www.camscanner.com/zh" } },
        { "tool": "execute_task", "args": { "task": "报告页面右上角是否有登录按钮或用户头像" } },
        { "tool": "screenshot" }
      ]
    },
    {
      "id": "SES-002",
      "name": "用户菜单检查",
      "description": "检查用户相关菜单",
      "steps": [
        { "tool": "navigate", "args": { "url": "https://www.camscanner.com/zh" } },
        { "tool": "execute_task", "args": { "task": "报告页面导航栏中与用户相关的按钮或链接" } },
        { "tool": "screenshot" }
      ]
    },
    {
      "id": "SES-003",
      "name": "登录入口位置",
      "description": "确认登录入口位置",
      "steps": [
        { "tool": "navigate", "args": { "url": "https://www.camscanner.com/zh" } },
        { "tool": "execute_task", "args": { "task": "描述登录按钮的位置和文字内容" } },
        { "tool": "screenshot" }
      ]
    },
    {
      "id": "SES-004",
      "name": "需登录页面拦截",
