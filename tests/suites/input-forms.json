        { "tool": "navigate", "args": { "url": "https://www.baidu.com" } },
        { "tool": "execute_task", "args": { "task": "在搜索框中输入 'CamScanner 扫描全能王'" } },
        { "tool": "screenshot" }
      ]
    },
    {
      "id": "INP-002",
      "name": "搜索框输入并提交",
      "description": "输入文本后提交搜索表单",
      "steps": [
        { "tool": "navigate", "args": { "url": "https://www.baidu.com" } },
        { "tool": "execute_task", "args": { "task": "在百度搜索框中输入 'CamScanner' 然后点击'百度一下'搜索按钮提交搜索" } },
        { "tool": "screenshot" }
      ]
    },
    {
      "id": "INP-003",
      "name": "通过索引输入文本",
