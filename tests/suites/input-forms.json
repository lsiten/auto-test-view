      "id": "INP-010",
      "name": "复选框和单选框",
      "description": "操作 checkbox 和 radio button",
      "steps": [
        { "tool": "navigate", "args": { "url": "https://www.camscanner.com/zh" } },
        { "tool": "execute_task", "args": { "task": "如果页面上有复选框(checkbox)，勾选第一个复选框；如果有单选按钮(radio)，选择第二个选项" } },
        { "tool": "screenshot" }
      ]
