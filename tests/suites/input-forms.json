      "steps": [
        { "tool": "navigate", "args": { "url": "https://www.baidu.com" } },
        { "tool": "execute_task", "args": { "task": "在搜索框中输入 'hello world'" } },
        { "tool": "execute_task", "args": { "task": "清除搜索框内容，然后输入 'auto test'" } },
        { "tool": "screenshot" }
      ]
    },
    {
      "id": "INP-007",
      "name": "输入特殊字符",
      "description": "在输入框中输入特殊字符",
      "steps": [
        { "tool": "navigate", "args": { "url": "https://www.baidu.com" } },
        { "tool": "execute_task", "args": { "task": "在搜索框中输入包含特殊字符的文本: '<script>alert(1)</script> & \"quotes\" 中文测试'" } },
        { "tool": "screenshot" }
      ]
    },
    {
