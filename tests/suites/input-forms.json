      "steps": [
        { "tool": "navigate", "args": { "url": "https://www.baidu.com" } },
        { "tool": "execute_task", "args": { "task": "使用 input_text 工具在百度搜索框中输入 'test input'" } },
        { "tool": "screenshot" }
      ]
    },
    {
      "id": "INP-004",
      "name": "清除并重新输入",
