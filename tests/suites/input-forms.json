      "steps": [
        { "tool": "navigate", "args": { "url": "https://www.baidu.com" } },
        { "tool": "execute_task", "args": { "task": "在搜索框中输入 'first input'" } },
        { "tool": "execute_task", "args": { "task": "清除搜索框中的内容，然后重新输入 'second input'" } },
        { "tool": "screenshot" }
      ]
    },
    {
      "id": "INP-005",
      "name": "登录表单填写",
      "description": "在百度搜索框中验证表单输入和提交",
      "steps": [
        { "tool": "navigate", "args": { "url": "https://www.baidu.com" } },
        { "tool": "execute_task", "args": { "task": "在搜索框中输入 'CamScanner 扫描全能王' 并提交搜索" } },
        { "tool": "screenshot", "note": "截图验证搜索结果" }
      ]
    },
    {
      "id": "INP-006",
      "name": "多字段表单填写",
